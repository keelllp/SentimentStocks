# Exclude large data files (keep .gitkeep so the directory exists in git for Docker COPY)
data/
processed_data/*
!processed_data/.gitkeep
venv/

# Exclude large file types
*.csv
*.xlsx
*.xls
*.parquet
*.h5
*.hdf5
*.pth
*.pt
*.onnx
*.pb

# Python cache and temporary files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints

# Results and outputs (can be large)
results/
outputs/
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.svg
*.pdf
*.eps
*.ps

# Logs
logs/
*.log
*.out
*.err

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Angel One session cache (contains live JWT tokens — never commit)
backend/.angel_session.json

# Per-day news sentiment cache
backend/news_cache/

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.old
node_modules/
frontend/node_modules/
